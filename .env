###############################################
# Environment variables for Vite (placeholders)
#
# Usa `.env.local` para tus valores reales.
# Este `.env` queda como plantilla SIN secretos.
# Vite solo expone variables prefijadas con `VITE_`.
###############################################

# EmailJS (requerido para el formulario de contacto)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_REQUEST=
VITE_EMAILJS_TEMPLATE_RESPONSE=
VITE_EMAILJS_PUBLIC_KEY=

# Firebase (opcional)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
